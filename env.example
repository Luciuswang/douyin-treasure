# =========================================
# Totofun 突突翻 - 环境变量配置
# 复制为 server/.env 并填入真实值
# =========================================

NODE_ENV=production
PORT=3001

# MongoDB
MONGODB_URI=mongodb://localhost:27017/totofun-treasure

# JWT（用 openssl rand -base64 32 生成）
JWT_SECRET=CHANGE_ME_TO_RANDOM_STRING
JWT_REFRESH_SECRET=CHANGE_ME_TO_ANOTHER_RANDOM_STRING
JWT_EXPIRES_IN=7d

# 客户端地址（用于 CORS）
CLIENT_URL=https://youkongwa.com

# AI 服务（DeepSeek）
DEEPSEEK_API_KEY=sk-your-key-here

# GitHub Webhook 签名密钥（可选，用 openssl rand -hex 20 生成）
WEBHOOK_SECRET=

# 高德地图 Key（前端用，配置在 client/.env）
# VITE_AMAP_KEY=your_amap_key
